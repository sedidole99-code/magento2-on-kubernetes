[mysqld]
# Base tunings — match the primary so memory/disk profiles align under load.
innodb_file_per_table           = 1
max_allowed_packet              = 256M
innodb_buffer_pool_size         = 384M
innodb_buffer_pool_chunk_size   = 128M
innodb_buffer_pool_instances    = 4
innodb_log_file_size            = 256M
innodb_log_files_in_group       = 2
innodb_flush_method             = O_DIRECT
innodb_flush_log_at_trx_commit  = 2
explicit_defaults_for_timestamp = 1
log_bin_trust_function_creators = 1

# Replication identity (server_id is templated per-pod by the entrypoint
# wrapper in scripts/bootstrap-replica.sh, derived as 100+ordinal so the
# two replicas are 100 and 101 — never colliding with the primary's
# server_id=1).
read_only                       = ON
super_read_only                 = ON
gtid_mode                       = ON
enforce_gtid_consistency        = ON
log_bin                         = /var/lib/mysql/mysql-bin
log_replica_updates             = OFF
binlog_format                   = ROW
relay_log                       = /var/lib/mysql/relay-bin

# Parallel apply (8.0 default sql_replica_skip_counter is fine; just turn on
# parallelism on commit groups for higher replication throughput).
slave_parallel_workers          = 4
slave_parallel_type             = LOGICAL_CLOCK

# Clone plugin must load on the recipient too — bootstrap-replica.sh issues
# CLONE INSTANCE FROM ... before any other startup work.
plugin_load_add                 = mysql_clone.so
