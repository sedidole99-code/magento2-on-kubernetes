AMQP_HOST=rabbitmq
AMQP_PORT=5672
AMQP_VIRTUALHOST=/
# Cron-driven consumers (magento-cron spawns these via cron_consumers_runner).
# Flip to 'false' + uncomment ../../bases/consumer in step-4/kustomization.yaml
# to switch back to the persistent worker Deployment.
CRON_CONSUMERS_RUNNER=true
CRON_CONSUMERS_MAX_MESSAGES=50
# Empty list = Magento runs every declared consumer (queue_consumer.xml) on each
# tick. Curate per-env by overriding CRON_CONSUMERS_LIST in an overlay's
# additional.env — comma-separated consumer names (core or custom).
CRON_CONSUMERS_LIST=
# Honoured by any queue:consumers:start invocation (cron- or Deployment-spawned):
# exit immediately on empty queue rather than polling forever.
CONSUMERS_WAIT_FOR_MESSAGES=0
# Only consulted when the magento-consumer Deployment is enabled; harmless otherwise.
CONSUMERS_MAX_MESSAGES=1000
